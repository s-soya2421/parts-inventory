{
  "name": "electronics-inventory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite --host 0.0.0.0",
    "dev:worker": "wrangler dev --local --persist-to .wrangler/state",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm test:web && pnpm test:integration",
    "test:api": "vitest run tests/api --pool=vmThreads --maxWorkers=1",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:web": "vitest run tests/web --pool=vmThreads --maxWorkers=1",
    "verify:cloudflare-secrets": "node ./scripts/verify-cloudflare-secrets.js",
    "deploy": "pnpm build && pnpm db:migrate:remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply parts-inventory --local",
    "db:migrate:remote": "wrangler d1 migrations apply parts-inventory --remote"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "hono": "^4.12.23",
    "jspdf": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@10.0.0"
}
